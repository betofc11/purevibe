{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and goals.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "number" },
        "macroGoals": {
          "type": "object",
          "properties": {
            "protein": { "type": "number" },
            "carbs": { "type": "number" },
            "fats": { "type": "number" },
            "calories": { "type": "number" }
          }
        },
        "bodyMetrics": {
          "type": "object",
          "properties": {
            "weight": { "type": "number" },
            "bodyFat": { "type": "number" },
            "muscleMass": { "type": "number" },
            "height": { "type": "number" },
            "updatedAt": { "type": "number" }
          }
        },
        "nutritionalPlan": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "calories": { "type": "number" },
            "protein": { "type": "number" },
            "carbs": { "type": "number" },
            "fats": { "type": "number" },
            "advice": { "type": "string" },
            "extractedAt": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email", "displayName", "createdAt"]
    },
    "DailyLog": {
      "title": "Daily Log",
      "description": "Stores daily nutritional intake and activities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "macros": {
          "type": "object",
          "properties": {
            "protein": { "type": "number" },
            "carbs": { "type": "number" },
            "fats": { "type": "number" },
            "calories": { "type": "number" }
          }
        },
        "meals": {
          "type": "array",
          "items": { "$ref": "Meal" }
        },
        "waterIntake": { "type": "number" }
      },
      "required": ["id", "userId", "date", "macros"]
    },
    "Meal": {
      "title": "Meal",
      "description": "A single meal entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "time": { "type": "string" },
        "macros": {
          "type": "object",
          "properties": {
            "protein": { "type": "number" },
            "carbs": { "type": "number" },
            "fats": { "type": "number" },
            "calories": { "type": "number" }
          }
        },
        "imageUrl": { "type": "string" }
      }
    },
    "StrengthRecord": {
      "title": "Strength Record",
      "description": "Personal bests for strength exercises.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "exercise": { "type": "string", "enum": ["Squat", "Bench Press", "Deadlift"] },
        "weight": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "exercise", "weight", "date"]
    },
    "BodyMetricsHistory": {
      "title": "Body Metrics History",
      "description": "Historical record of user body metrics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "weight": { "type": "number" },
        "bodyFat": { "type": "number" },
        "muscleMass": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "weight", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document. Acts as 'estado_actual' for profile data."
    },
    "/users/{userId}/dailyLogs/{logId}": {
      "schema": "DailyLog",
      "description": "Daily logs for a user. Acts as 'estado_actual' for daily macros and meal history."
    },
    "/users/{userId}/strengthRecords/{recordId}": {
      "schema": "StrengthRecord",
      "description": "Strength records for a user."
    },
    "/users/{userId}/bodyMetricsHistory/{historyId}": {
      "schema": "BodyMetricsHistory",
      "description": "Historical body metrics for tracking progress."
    }
  }
}
